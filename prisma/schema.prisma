datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

generator dbml {
  provider               = "prisma-dbml-generator"
  output                 = "./output"
  outputName             = "database.dbml"
  projectName            = "DanceSuite"
  projectDatabaseType    = "PostgreSQL"
  projectDatabaseVersion = "1.0.0"
  includeRelationFields  = false
}

model competition_schedule {
  uid            String      @id @unique @default(uuid()) @db.Uuid
  created        DateTime    @default(now())
  updated        DateTime    @updatedAt
  competition_id String      @db.Uuid
  competition    competition @relation(fields: [competition_id], references: [uid])
  title          String?
  description    String?
  start_time     DateTime?
  end_time       DateTime?
  venue          String?
  heat           heat[]
}

model panels {
  uid                 String                @id @unique @default(uuid()) @db.Uuid
  created             DateTime              @default(now())
  updated             DateTime              @updatedAt
  competition_id      String                @db.Uuid
  competition         competition           @relation(fields: [competition_id], references: [uid])
  name                String?               @db.Text
  is_deleted          Boolean               @default(false)
  deleted_at          DateTime?
  deleted_by_id       String?               @db.Uuid
  panels_adjudicators panels_adjudicators[]
  heat                heat[]
  competition_log     competition_log[]
}

model panels_adjudicators {
  uid            String      @id @unique @default(uuid()) @db.Uuid
  created        DateTime    @default(now())
  updated        DateTime    @updatedAt
  panel_id       String      @db.Uuid
  panel          panels      @relation(fields: [panel_id], references: [uid])
  adjudicator_id String      @db.Uuid
  adjudicator    adjudicator @relation(fields: [adjudicator_id], references: [uid])
  is_deleted     Boolean     @default(false)
  deleted_at     DateTime?
  deleted_by_id  String?     @db.Uuid
}

model section_result {
  uid           String   @id @unique @default(uuid()) @db.Uuid
  created       DateTime @default(now())
  updated       DateTime @updatedAt
  section_id    String   @db.Uuid
  section       sections @relation(fields: [section_id], references: [uid], onDelete: Cascade)
  dancer_id     String   @db.Uuid
  dancer        dancers  @relation(fields: [dancer_id], references: [uid])
  dancer_number Int
  position      Int
}

model heat_result {
  uid                String               @id @unique @default(uuid()) @db.Uuid
  created            DateTime             @default(now())
  updated            DateTime             @updatedAt
  heat_id            String               @db.Uuid
  section_id         String               @db.Uuid
  section            sections             @relation(fields: [section_id], references: [uid], onDelete: Cascade)
  heat               heat                 @relation(fields: [heat_id], references: [uid])
  created_by_id      String               @db.Uuid
  created_by         competition_users    @relation(fields: [created_by_id], references: [uid])
  heat_result_dancer heat_result_dancer[]
}

model heat_result_dancer {
  uid            String      @id @unique @default(uuid()) @db.Uuid
  created        DateTime    @default(now())
  updated        DateTime    @updatedAt
  dancer_id      String      @db.Uuid
  dancer         dancers     @relation(fields: [dancer_id], references: [uid])
  heat_result_id String      @db.Uuid
  heat_result    heat_result @relation(fields: [heat_result_id], references: [uid], onDelete: Cascade)
  no_callbacks   Int         @default(0)
  callback       Boolean     @default(false)
  postiion       Int?
}

enum HeatMarkInputType {
  JUDGE
  SCRUTINEER
}

model heat_marks {
  uid            String             @id @unique @default(uuid()) @db.Uuid
  created        DateTime           @default(now())
  updated        DateTime           @updatedAt
  heat_id        String             @db.Uuid
  heat           heat               @relation(fields: [heat_id], references: [uid], onDelete: Cascade)
  adjudicator_id String             @db.Uuid
  adjudicator    adjudicator        @relation(fields: [adjudicator_id], references: [uid])
  ip_address     String?
  signature      String?
  check_sum      String?
  input_type     HeatMarkInputType  @default(JUDGE)
  scrutineer_id  String?            @db.Uuid
  scrutineer     competition_users? @relation(fields: [scrutineer_id], references: [uid])
  marks          marks[]
}

model adjudicator {
  uid                 String                @id @unique @default(uuid()) @db.Uuid
  created             DateTime              @default(now())
  updated             DateTime              @updatedAt
  name                String
  letter              String
  login_code          String?
  token               String?
  last_login          DateTime?
  email               String?
  competition_id      String                @db.Uuid
  competition         competition           @relation(fields: [competition_id], references: [uid])
  is_deleted          Boolean               @default(false)
  deleted_at          DateTime?
  deleted_by_id       String?               @db.Uuid
  panels_adjudicators panels_adjudicators[]
  heat_marks          heat_marks[]
}

enum LicenseType {
  FREE
  PRO
  ENTERPRISE
}

model user_license {
  uid               String      @id @unique @default(uuid()) @db.Uuid
  created           DateTime    @default(now())
  updated           DateTime    @updatedAt
  user_id           String      @db.Uuid // Clerk Uid
  license_type      LicenseType @default(FREE)
  expiration_date   DateTime?
  stripe_invoice_id String?
}

model marks {
  uid           String     @id @unique @default(uuid()) @db.Uuid
  created       DateTime   @default(now())
  updated       DateTime   @updatedAt
  dancer_number Int
  dancer_id     String?    @db.Uuid
  dancer        dancers?   @relation(fields: [dancer_id], references: [uid], onDelete: Cascade)
  heat_mark_id  String     @db.Uuid
  heat_mark     heat_marks @relation(fields: [heat_mark_id], references: [uid], onDelete: Cascade)
  mark          Int?
  percentage    Int?
  dance         String
}

enum CompetitiveType {
  COMPETITIVE
  SOCIAL
  MIXED_COMPETITIVE
}

enum SectionAgeGroup {
  TINY_TOTS
  JUVENILE
  JUNIOR
  YOUTH
  ADULT
  SENIOR
  AMATEUR
  PROFFESSIONAL
  MASTERS
}

enum SectionLevel {
  BEGINNER
  BRONZE
  SILVER
  GOLD
  NOVICE
  PRE_CHAMP
  RISING_STAR
  CHAMPIONSHIP
}

enum SectionCategory {
  BALLROOM
  LATIN
  TEN_DANCE
  STANDARD
  HIP_HOP
  FREESTYLE
  TRADITIONAL
}

enum SectionEntryType {
  SOLO
  DUO
  COUPLE
  GROUP
}

model sections {
  uid              String            @id @unique @default(uuid()) @db.Uuid
  created          DateTime          @default(now())
  updated          DateTime          @updatedAt
  competition_id   String?           @db.Uuid
  competition      competition?      @relation(fields: [competition_id], references: [uid])
  name             String?
  age_group        SectionAgeGroup?
  level            SectionLevel?
  entry_type       SectionEntryType?
  category         SectionCategory?
  custom_name      Boolean           @default(false)
  competitive_type CompetitiveType   @default(COMPETITIVE)
  section_result   section_result[]
  heat_result      heat_result[]
  heat             heat[]
  competition_log  competition_log[]
  dancers          dancers[]
}

enum HeatType {
  ROUND
  QUARTER_FINAL
  SEMI_FINAL
  FINAL
  UNCONTESTED
}

enum HeatStatus {
  DRAFT // not yet started
  ACTIVE // heat ready for marshalling
  MARSHALLING // marshalling in progress, collecting all dancers
  READY // marshalling complete, heat ready to start
  JUDGING // heat in progress
  REVIEWING // heat complete, results being reviewed by scrutineer
  CHECKING // results reviewed by chairperson, ready for final check
  COMPLETE // heat complete, results final
  CANCELED // heat canceled
}

model heat {
  uid             String                @id @unique @default(uuid()) @db.Uuid
  created         DateTime              @default(now())
  updated         DateTime              @updatedAt
  section_id      String                @db.Uuid
  section         sections              @relation(fields: [section_id], references: [uid], onDelete: Cascade)
  order           Int?
  item_no         String
  status          HeatStatus            @default(DRAFT)
  type            HeatType              @default(ROUND)
  callback_limit  Int?
  dances          String[]
  start_list      dancers[]
  panel_id        String?               @db.Uuid
  panel           panels?               @relation(fields: [panel_id], references: [uid])
  schedule_id     String?               @db.Uuid
  schedule        competition_schedule? @relation(fields: [schedule_id], references: [uid])
  reviewed_by_id  String?               @db.Uuid
  reviewed_by     competition_users?    @relation("competition_user_heat_reviewed_by", fields: [reviewed_by_id], references: [uid])
  reviewed_at     DateTime?
  checked_by_id   String?               @db.Uuid
  checked_by      competition_users?    @relation("competition_user_heat_checked_by", fields: [checked_by_id], references: [uid])
  checked_at      DateTime?
  heat_result     heat_result[]
  heat_marks      heat_marks[]
  competition_log competition_log[]
}

enum CompetitionLogEventType {
  COMPETITION_CREATED
  COMPETITION_STARTED
  COMPETITION_COMPLETED
  COMPETITION_ARCHIVED

  SECTION_CREATED
  SECTION_EDITED
  SECTION_DELETED

  // DANCER ACTIONS
  DANCER_REGISTERED
  DANCER_ADDED
  DANCER_EDITED
  DANCER_WITHDRAWN

  HEAT_CREATED
  HEAT_EDITED
  HEAT_DELETED

  // HEAT ACTIONS
  HEAT_ACTIVE // heat ready for marshalling
  HEAT_MARSHALLING // marshalling in progress, collecting all dancers
  HEAT_READY // marshalling complete, heat ready to start
  HEAT_JUDGING // heat in progress
  HEAT_REVIEWING // heat complete, results being reviewed by scrutineer
  HEAT_CHECKING // results reviewed by chairperson, ready for final check
  HEAT_COMPLETE // heat complete, results final
  HEAT_CANCELED // heat canceled

  HEAT_MARKS_ENTERED // Scrutineer has entered marks
  HEAT_MARKS_SUBMITTED // Judge Has Entered the marks

  COMPETITION_USER_CREATED
  COMPETITION_USER_EDITED
  COMPETITION_USER_DELETED

  PANEL_CREATED
  PANEL_EDITED
  PANEL_DELETED

  COMPETITION_NOTE_ADDED
  COMPETITION_NOTE_EDITED
  COMPETITION_NOTE_DELETED

  SYSTEM_EVENT
}

model competition_log {
  uid            String                  @id @unique @default(uuid()) @db.Uuid
  created        DateTime                @default(now())
  updated        DateTime                @updatedAt
  competition_id String                  @db.Uuid
  competition    competition             @relation(fields: [competition_id], references: [uid], onDelete: Cascade)
  user_id        String?                 @db.Uuid
  user           competition_users?      @relation(fields: [user_id], references: [uid])
  event_type     CompetitionLogEventType
  note           String?
  data           Json?
  heat_id        String?                 @db.Uuid
  heat           heat?                   @relation(fields: [heat_id], references: [uid])
  dancer_id      String?                 @db.Uuid
  dancer         dancers?                @relation(fields: [dancer_id], references: [uid])
  panel_id       String?                 @db.Uuid
  panel          panels?                 @relation(fields: [panel_id], references: [uid])
  section_id     String?                 @db.Uuid
  section        sections?               @relation(fields: [section_id], references: [uid])
}

enum CompetitionStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
  ARCHIVED
}

model competition {
  uid                  String                 @id @unique @default(uuid()) @db.Uuid
  created              DateTime               @default(now())
  updated              DateTime               @updatedAt
  name                 String
  venue                String?
  date                 DateTime?
  organizer_name       String?
  organizer_email      String?
  organization         String?
  website              String?
  is_deleted           Boolean                @default(false)
  deleted_at           DateTime?
  deleted_by_id        String?                @db.Uuid
  status               CompetitionStatus      @default(DRAFT)
  competition_schedule competition_schedule[]
  panels               panels[]
  adjudicator          adjudicator[]
  sections             sections[]
  competition_log      competition_log[]
  competition_users    competition_users[]
  competition_notes    competition_notes[]
}

enum CompetitionUserRole {
  ADMIN
  SCRUTINEER
  JUDGE
  OFFICIAL
  VIEWER
}

model competition_users {
  uid            String              @id @unique @default(uuid()) @db.Uuid
  created        DateTime            @default(now())
  updated        DateTime            @updatedAt
  competition_id String              @db.Uuid
  competition    competition         @relation(fields: [competition_id], references: [uid])
  user_id        String              @db.Uuid // Clerk Uid
  role           CompetitionUserRole @default(VIEWER)
  is_deleted     Boolean             @default(false)
  deleted_at     DateTime?
  is_active      Boolean             @default(true)

  // relationships
  heat_reviewed_by  heat[]            @relation("competition_user_heat_reviewed_by")
  heat_checked_by   heat[]            @relation("competition_user_heat_checked_by")
  dancer_created_by dancers[]         @relation("dancer_created_by")
  dancer_updated_by dancers[]         @relation("dancer_updated_by")
  dancer_deleted_by dancers[]         @relation("dancer_deleted_by")
  heat_result       heat_result[]
  heat_marks        heat_marks[]
  competition_log   competition_log[]
}

model competition_notes {
  uid            String      @id @unique @default(uuid()) @db.Uuid
  created        DateTime    @default(now())
  updated        DateTime    @updatedAt
  competition_id String      @db.Uuid
  competition    competition @relation(fields: [competition_id], references: [uid])
  user_id        String      @db.Uuid
  note           String
  attachmentUrls String[]
}

enum DancerCreatedByType {
  SCRUTINEER
  IMPORT
  OFFICIAL
}

model dancers {
  uid                String               @id @unique @default(uuid()) @db.Uuid
  created            DateTime             @default(now())
  updated            DateTime             @updatedAt
  number             Int?
  name               String?
  partner_name       String?
  studio             String?
  region             String?
  country            String?
  section_id         String               @db.Uuid
  section            sections             @relation(fields: [section_id], references: [uid], onDelete: Cascade)
  meta_data          Json?
  created_type       DancerCreatedByType  @default(SCRUTINEER)
  created_by_id      String?              @db.Uuid
  created_by         competition_users?   @relation("dancer_created_by", fields: [created_by_id], references: [uid])
  updated_by_id      String?              @db.Uuid
  updated_by         competition_users?   @relation("dancer_updated_by", fields: [updated_by_id], references: [uid])
  deleted_by_id      String?              @db.Uuid
  deleted_by         competition_users?   @relation("dancer_deleted_by", fields: [deleted_by_id], references: [uid])
  section_result     section_result[]
  heat_result_dancer heat_result_dancer[]
  marks              marks[]
  heat               heat?                @relation(fields: [heatUid], references: [uid])
  heatUid            String?              @db.Uuid
  competition_log    competition_log[]
}
